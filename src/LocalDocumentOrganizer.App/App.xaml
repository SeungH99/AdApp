<Application
    x:Class="LocalDocumentOrganizer.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFDFB" />
                    <SolidColorBrush x:Key="AppPanelBrush" Color="#FFFFFFFF" />
                    <SolidColorBrush x:Key="AppNavBrush" Color="#FFFDFB" />
                    <SolidColorBrush x:Key="AppTextBrush" Color="#FF121412" />
                    <SolidColorBrush x:Key="AppSubtleTextBrush" Color="#FF61675F" />
                    <SolidColorBrush x:Key="AppBorderBrush" Color="#FFE0E4DE" />
                    <SolidColorBrush x:Key="AppSelectionBrush" Color="#FFFCFFF5" />
                    <SolidColorBrush x:Key="AppControlBrush" Color="#FFF4F6F2" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FF141714" />
                    <SolidColorBrush x:Key="AppPanelBrush" Color="#FF191C19" />
                    <SolidColorBrush x:Key="AppNavBrush" Color="#FF111411" />
                    <SolidColorBrush x:Key="AppTextBrush" Color="#FFF4F6F1" />
                    <SolidColorBrush x:Key="AppSubtleTextBrush" Color="#FFB7BDB4" />
                    <SolidColorBrush x:Key="AppBorderBrush" Color="#FF343A32" />
                    <SolidColorBrush x:Key="AppSelectionBrush" Color="#FF26350F" />
                    <SolidColorBrush x:Key="AppControlBrush" Color="#FF252A24" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <SolidColorBrush x:Key="AppAccentBrush" Color="#FFB7EF00" />
            <SolidColorBrush x:Key="AppAccentTextBrush" Color="#FF111600" />
            <SolidColorBrush x:Key="AppRiskBrush" Color="#FFE3312B" />
            <SolidColorBrush x:Key="AppWarningBrush" Color="#FFD96D00" />
            <SolidColorBrush x:Key="AppInfoBrush" Color="#FF0866CC" />

            <Style x:Key="NavButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Foreground" Value="{ThemeResource AppTextBrush}" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="Padding" Value="14,10" />
                <Setter Property="Margin" Value="0,2" />
                <Setter Property="MinHeight" Value="42" />
            </Style>

            <Style x:Key="MetricCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource AppPanelBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="14,12" />
                <Setter Property="Margin" Value="0,0,10,0" />
            </Style>

            <Style x:Key="SubtleTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource AppSubtleTextBrush}" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource AppTextBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="14" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
